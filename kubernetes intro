### httpd container inside a pod
---
apiVersion: v1
kind: Pod
metadata:
  name: httpd
  labels:
    app: httpd
    purpose: test
    env: dev
spec:
  containers:
   - name: httpd
     image: httpd:latest
     ports:
      - name: httpd
        protocol: TCP
        containerPort: 80

  
