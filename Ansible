--------------------------------------
MULTIPLE WEB APP INSTALL WITH PLAYBOOK
--------------------------------------
---
- name: Install and Start NGINX
  hosts: dev
  become: yes
  gather_facts: yes

  tasks:

    - name: Update apt package cache
      apt:
        update_cache: yes
      when: ansible_facts['os_family'] == "Debian"

    - name: Installing multiple packages
      apt:
        name:
          - git
          - nginx
          - curl
        state: present

