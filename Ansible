---------------------------------
ALL IN ONE YAML ansible playbook
---------------------------------
- name: File and Directory Management
  hosts: all
  become: yes

  tasks:

    - name: Create a directory
      file:
        path: /opt/devops
        state: directory
        mode: '0755'

    - name: Create a new empty file
      file:
        path: /opt/devops/info.txt
        state: touch
        mode: '0644'

    - name: Copy existing file to nodes
      copy:
        src: sample.txt
        dest: /opt/devops/sample.txt
        mode: '0644'

    - name: Copy existing directory to nodes
      copy:
        src: appfiles/



