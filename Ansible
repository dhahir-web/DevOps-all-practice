-----------------------------------
ANSIBLE PLAYBOOK
-----------------------------------

vi nginx.yaml

---
- name: Install and Start NGINX
  hosts: all
  become: yes

  tasks:

    - name: Update apt package cache
      apt:
        update_cache: yes
      when: ansible_os_family == "Debian"

    - name: Install NGINX
      package:
        name: nginx
        state: present

    - name: Start and Enable NGINX
      service:
        name: nginx

